# Telegram MTProto credentials
# Get these from https://my.telegram.org/apps
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here

# Session name (will create a .session file)
TG_SESSION_NAME=bridge_session

# Groups to watch (comma-separated MTProto channel IDs, without -100 prefix)
# Example: 1234567890,9876543210
BRIDGE_GROUPS=your_channel_id_here

# Bot configurations (JSON format)
# Each bot needs: username, discord_id (optional), and which bots it should NOT relay to itself
# Example: [{"username": "mybot", "alts": ["mybot", "my_bot"], "mention": "@mybot"}]
BRIDGE_BOTS='[{"username": "bot1_username", "alts": ["bot1_username"], "mention": "@bot1_username"}, {"username": "bot2_username", "alts": ["bot2_username"], "mention": "@bot2_username"}]'

# Timing configuration
MENTION_SILENCE=5
DELETE_DELAY=2
EDIT_THROTTLE=1.5
